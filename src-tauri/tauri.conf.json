{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DSHub",
  "version": "0.1.0",
  "identifier": "io.dshub.app",
  "build": {
    "frontendDist": "../client/build",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm --prefix client run dev",
    "beforeBuildCommand": "npm --prefix client run build"
  },
  "app": {
    "windows": [
      {
        "title": "DSHub",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

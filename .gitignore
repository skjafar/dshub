# ============================================
# DSHub - Unified .gitignore
# ============================================

# ============================================
# Dependencies
# ============================================
node_modules/
client/node_modules/
/.pnp
.pnp.js
jspm_packages/

# ============================================
# Build Output & Distribution
# ============================================
dist/
build/
client/build/
client/dist/
*.js.map
*.css.map

# ============================================
# Environment Variables
# ============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
client/.env.local
client/.env.development.local
client/.env.test.local
client/.env.production.local

# ============================================
# Testing & Coverage
# ============================================
/coverage
client/coverage/
*.lcov

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# PM2 Logs
.pm2/
pm2-*.log

# ============================================
# Runtime Data
# ============================================
pids
*.pid
*.seed
*.pid.lock

# ============================================
# Cache & Temporary Files
# ============================================
.npm
.eslintcache
.cache
.parcel-cache
.node_repl_history
*.tgz
.vite/
client/.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ============================================
# Yarn
# ============================================
.yarn-integrity
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ============================================
# Serverless & Cloud
# ============================================
.serverless
.fusebox/
.dynamodb/

# ============================================
# IDE & Editor Files
# ============================================
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project
.tern-port

# ============================================
# OS Generated Files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ============================================
# Python (Emulator)
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# ============================================
# TypeScript
# ============================================
*.tsbuildinfo
.tsbuildinfo
tsconfig.tsbuildinfo

# ============================================
# AUR Package Build Artifacts
# ============================================
aur/pkg/
aur/src/
aur/*.pkg.tar.zst
aur/*.pkg.tar.xz
aur/*.tar.gz
aur/dshub/

# ============================================
# Development & Documentation (Keep in Git)
# ============================================
# Keep these files - they're important
!README.md
!QUICK_START.md
!DEPLOYMENT-PM2.md
!VITE-MIGRATION.md
!emulator/README.md
!aur/README.md
!client/public/maps/*.map
!ecosystem.config.js
!vite.config.ts
!tsconfig*.json
!aur/PKGBUILD
!aur/.SRCINFO
!aur/*.service
!aur/*.desktop
!aur/*.install
!aur/config.env

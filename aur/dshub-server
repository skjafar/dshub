#!/bin/bash
# DSHub Server Wrapper

ACTION="${1:-help}"

case "$ACTION" in
    start)
        sudo systemctl start dshub
        echo "DSHub started"
        echo "Access at: http://localhost:3002"
        ;;
    stop)
        sudo systemctl stop dshub
        echo "DSHub stopped"
        ;;
    restart)
        sudo systemctl restart dshub
        echo "DSHub restarted"
        ;;
    status)
        systemctl status dshub
        ;;
    logs)
        journalctl -u dshub -f
        ;;
    enable)
        sudo systemctl enable dshub
        echo "DSHub enabled (auto-start on boot)"
        ;;
    disable)
        sudo systemctl disable dshub
        echo "DSHub disabled (no auto-start)"
        ;;
    open)
        xdg-open http://localhost:3002
        ;;
    *)
        echo "DSHub - Device Monitoring Application"
        echo ""
        echo "Usage: dshub <command>"
        echo ""
        echo "Commands:"
        echo "  start    - Start the service"
        echo "  stop     - Stop the service"
        echo "  restart  - Restart the service"
        echo "  status   - Show service status"
        echo "  logs     - Show live logs"
        echo "  enable   - Enable auto-start on boot"
        echo "  disable  - Disable auto-start"
        echo "  open     - Open in browser"
        echo ""
        echo "Configuration: /etc/dshub/config.env"
        echo "Documentation: /usr/share/doc/dshub/"
        echo ""
        ;;
esac

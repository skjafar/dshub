#!/bin/bash
# DSHub Emulator Wrapper

ACTION="${1:-help}"

case "$ACTION" in
    start)
        sudo systemctl start dshub-emulator
        echo "DSHub Emulator started"
        echo "Listening on localhost (UDP discovery on port 2011)"
        ;;
    stop)
        sudo systemctl stop dshub-emulator
        echo "DSHub Emulator stopped"
        ;;
    restart)
        sudo systemctl restart dshub-emulator
        echo "DSHub Emulator restarted"
        ;;
    status)
        systemctl status dshub-emulator
        ;;
    logs)
        journalctl -u dshub-emulator -f
        ;;
    enable)
        sudo systemctl enable dshub-emulator
        echo "DSHub Emulator enabled (auto-start on boot)"
        ;;
    disable)
        sudo systemctl disable dshub-emulator
        echo "DSHub Emulator disabled (no auto-start)"
        ;;
    run)
        # Run emulator directly (not as service)
        cd /opt/dshub/emulator
        python3 dshub_emulator.py
        ;;
    *)
        echo "DSHub Board Emulator"
        echo ""
        echo "Usage: dshub-emulator <command>"
        echo ""
        echo "Commands:"
        echo "  start    - Start the emulator service"
        echo "  stop     - Stop the emulator service"
        echo "  restart  - Restart the emulator service"
        echo "  status   - Show service status"
        echo "  logs     - Show live logs"
        echo "  enable   - Enable auto-start on boot"
        echo "  disable  - Disable auto-start"
        echo "  run      - Run emulator directly (foreground)"
        echo ""
        echo "Documentation: /opt/dshub/emulator/README.md"
        echo ""
        ;;
esac

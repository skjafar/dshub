# DeviceMon Web Configuration
# Located at: /etc/devicemon-web/config.env

# Server Port
PORT=3002

# Node Environment
NODE_ENV=production

# Build Optimizations (for manual builds)
TSC_COMPILE_ON_ERROR=true
GENERATE_SOURCEMAP=false

# Client Server URL (optional - auto-detects if not set)
# VITE_SERVER_URL=http://localhost:3002

# Logging Level
# Options: error, warn, info, debug
LOG_LEVEL=info

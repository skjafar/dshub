pkgbase = dshub
	pkgdesc = DSHub - Modern web application for monitoring and controlling embedded devices via TCP/UDP
	pkgver = 0.1.0
	pkgrel = 1
	url = https://github.com/skjafar/dshub
	install = dshub.install
	arch = x86_64
	arch = aarch64
	license = MIT
	makedepends = git
	makedepends = npm
	depends = nodejs>=18.0.0
	depends = npm
	optdepends = python: for board emulator
	optdepends = pm2: for process management (recommended)
	backup = etc/dshub/config.env
	backup = etc/dshub/maps/registers.map
	backup = etc/dshub/maps/parameters.map
	backup = etc/dshub/maps/boardtypes.map
	source = git+https://github.com/skjafar/dshub.git#tag=v0.1.0
	sha256sums = SKIP

pkgname = dshub
